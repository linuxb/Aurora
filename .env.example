# arqo
ARQO_ADDR=:8080
ARQO_SCHEDULER_BACKEND=memory
ARQO_MYSQL_DSN=aurora:aurora@tcp(127.0.0.1:3306)/aurora?parseTime=true&multiStatements=true
ARQO_TIDB_DSN=root@tcp(127.0.0.1:4000)/aurora?parseTime=true&multiStatements=true
ARQO_EVENT_BACKEND=memory
ARQO_REDIS_ADDR=127.0.0.1:6379
ARQO_REDIS_DB=0
ARQO_REDIS_CHANNEL_PREFIX=aurora

# worker-ts
ARQO_URL=http://127.0.0.1:8080
WORKER_ID=worker-ts-1
WORKER_LOOP_INTERVAL_MS=800

# polaris
POLARIS_ADDR=127.0.0.1:8082
